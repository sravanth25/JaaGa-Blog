# API Key for securing automated blog post creation from external services like n8n
BLOG_API_KEY=your_secure_randomly_generated_key_here

# Persistent GitHub Synchronization (Recommended for Vercel, Cloud Run, etc.)
# Set these in your deployment settings so that automated blogs are automatically backed up to GitHub
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your_username/your_repo_name
GITHUB_BRANCH=main
GITHUB_PATH=artifacts/api-server/data/posts.json
