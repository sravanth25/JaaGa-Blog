{
  "buildCommand": "node vercel-build.mjs",
  "outputDirectory": "dist",
  "installCommand": "echo 'skip'",
  "framework": null,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
